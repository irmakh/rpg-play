DB_PROVIDER=instantdb
# DB_PROVIDER options:
#   instantdb  — cloud database (requires INSTANT_APP_ID + INSTANT_ADMIN_TOKEN)
#   localdb    — local SQLite + WebSocket (no cloud credentials needed)

INSTANT_APP_ID=your-instantdb-app-id
INSTANT_ADMIN_TOKEN=your-instantdb-admin-token   # not required when DB_PROVIDER=localdb
MASTER_PASSWORD=your-dm-master-password
PORT=80
# WS_URL=ws://192.168.1.100:80/ws
# WS_URL — optional, overrides the WebSocket address used by browser clients.
#           Useful when the server is on a different host/IP than the page origin.
#           If unset, clients default to ws://<page-host>/ws
