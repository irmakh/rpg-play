DB_PROVIDER=localdb
# DB_PROVIDER options:
#   localdb    — local SQLite + WebSocket (no cloud credentials needed) — recommended
#   instantdb  — cloud database (requires INSTANT_APP_ID + INSTANT_ADMIN_TOKEN)

MASTER_PASSWORD=your-dm-master-password

# InstantDB — only required when DB_PROVIDER=instantdb
# INSTANT_APP_ID=your-instantdb-app-id
# INSTANT_ADMIN_TOKEN=your-instantdb-admin-token

# Port — defaults to 3000 (HTTP) or 443 (HTTPS if SSL certs are set)
# PORT=3000

# SSL — leave unset for local development (plain HTTP on port 3000)
# Set both to enable HTTPS + automatic HTTP→HTTPS redirect in production
# SSL_KEY=/etc/letsencrypt/live/your-domain.com/privkey.pem
# SSL_CERT=/etc/letsencrypt/live/your-domain.com/fullchain.pem

# WebSocket URL override — only needed when clients connect from a different host/IP
# WS_URL=wss://your-domain.com/ws
